# direnv config (committed). Non-secret, project-wide env vars live here.
# Secrets live in .envrc.local (gitignored) — copy .envrc.local.example to it.
# Run `direnv allow` after editing either file.

# --- Non-secret project vars go here (none yet) ---
export FLY_PG_APP=relay-db
export GOOGLE_CLIENT_ID=1033120416481-s646skvhq8r4edu599vf625f86d41bp5.apps.googleusercontent.com

# Auto-trust the mise configs in the runner's long-lived worktrees, so a freshly
# checked-out worktree (a new path) can run its pinned toolchain (flutter/mix)
# without a `mise trust` prompt. The runner is launched from a direnv shell here,
# so its worktree subprocesses inherit this. ($PWD is the repo root at load time.)
export MISE_TRUSTED_CONFIG_PATHS="$PWD/.claude/worktrees"

# Use the committed git hooks (.githooks/pre-commit auto-formats staged Dart so
# nothing unformatted is ever committed/pushed — matches CI's `dart format` check).
# Idempotent; runs on direnv load so every clone/worktree picks it up.
git config core.hooksPath .githooks 2>/dev/null || true

# --- Secrets + per-developer overrides ---
source_env_if_exists ./.envrc.local
