<!DOCTYPE html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <link rel="icon" type="image/png" href={~p"/images/logo_light_128.png"} />
    <.live_title default="Relay" suffix=" · Relay" phx-no-format>{assigns[:page_title]}</.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      // QUICKFIX: dark mode is broken, so force light everywhere until it's fixed.
      // Clears any stored/"system" preference so the OS can't pull in the dark theme.
      // To restore theme switching, revert this block and the hidden <.theme_toggle />.
      (() => {
        try { localStorage.removeItem("phx:theme"); } catch (e) {}
        document.documentElement.setAttribute("data-theme", "light");
      })();
    </script>
  </head>
  <body>
    {@inner_content}
    <%!-- RLY-157: one shared full-size image viewer for every page — LiveView board
          pages and dead controller pages (docs, landing, legal) alike. --%>
    <.image_lightbox />
  </body>
</html>
