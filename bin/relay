#!/usr/bin/env python3
"""relay — one tool for a Relay board: a REST-API CLI, and (with no arguments) a
board *runner* that watches the board and drives ready cards through a pipeline.

This file is generic: it knows the Relay REST API and how to watch/dispatch, but
NOTHING about any particular board's columns, agents, or skills. All of that —
the pipeline, and what to run when a card is ready at each stage — lives in
`relay_config.json` (see its `_comment`). The runner just executes the steps it
finds there.

Config (env): RELAY_URL, RELAY_API_KEY  (a board key from /board/settings)

  relay                       # run the board runner (watch loop)
  relay watch [--once] [--dry-run] [--interval N]
  relay board [--json]        relay card REF [--json]     relay pull [--json]
  relay comment REF TEXT      relay move REF STAGE        relay status REF STATUS
  relay create TITLE [--stage N]  relay describe REF TEXT   relay needs-input REF Q
  relay own REF / release REF relay approve REF           relay reject REF NOTE [--to STAGE]
  relay sub-tasks REF @file   relay check REF ID / uncheck REF ID   relay result REF @file
  relay layout   # config skeleton

TEXT/Q/NOTE accept "-" (stdin) or "@path" (file). --json for machine output.
"""
import argparse
import hashlib
import json
import os
import re
import subprocess
import sys
import time
import urllib.error
import urllib.request

HERE = os.path.abspath(__file__)
ROOT = os.path.dirname(os.path.dirname(HERE))
CONFIG_PATH = os.path.join(ROOT, "relay_config.json")
STATE_PATH = os.path.join(ROOT, ".relay-watch-state.json")
DRY = False


def die(msg):
    print(f"relay: {msg}", file=sys.stderr)
    sys.exit(1)


def log(msg):
    print(f"[relay] {msg}", flush=True)


def banner(lines):
    """Print a prominent #-rule banner around `lines` in the runner feed.

    Every physical line goes through log(), so it keeps the "[relay] " prefix and
    interleaves/greps cleanly with the rest of the streamed feed. Fixed 63-wide rule
    (no terminal-width detection) so logs and CI output stay deterministic."""
    rule = "#" * 63
    log("")
    log(rule)
    for line in lines:
        log(f"## {line}")
    log(rule)


# ============================ REST API client ============================

def env(name):
    v = os.environ.get(name)
    return v or die(f"{name} is not set")


def api(method, path, body=None, soft_404=False):
    url = env("RELAY_URL").rstrip("/") + path
    data = json.dumps(body).encode() if body is not None else None
    req = urllib.request.Request(url, data=data, method=method)
    req.add_header("Authorization", f"Bearer {env('RELAY_API_KEY')}")
    if data is not None:
        req.add_header("Content-Type", "application/json")
    try:
        with urllib.request.urlopen(req) as resp:
            raw = resp.read()
            return json.loads(raw) if raw else {}
    except urllib.error.HTTPError as e:
        if soft_404 and e.code == 404:
            return None
        try:
            msg = json.loads(e.read())["error"]["message"]
        except Exception:
            msg = f"HTTP {e.code}"
        die(f"API {e.code}: {msg}")
    except urllib.error.URLError as e:
        die(f"request failed: {e.reason}")


def read_arg(text):
    if text == "-":
        return sys.stdin.read()
    if text.startswith("@"):
        with open(text[1:], encoding="utf-8") as f:
            return f.read()
    return text


def get_board():
    return api("GET", "/api/board")


def get_board_version():
    """Cheap board-changed poll: the version int, or None if the server lacks
    the endpoint (older server) so the caller falls back to a full-board poll."""
    resp = api("GET", "/api/board/version", soft_404=True)
    return resp["version"] if resp else None


def get_card(ref):
    return api("GET", f"/api/cards/{ref}")["data"]


def resolve_stage_id(name, board=None):
    board = board or get_board()
    for s in board["stages"]:
        if s["name"] == name:
            return s["id"]
    die(f'no stage named "{name}". stages: ' + ", ".join(s["name"] for s in board["stages"]))


# board mutations (used by both the CLI and the runner)
def own(ref):
    return api("PATCH", f"/api/cards/{ref}", {"owners": ["agent"]})["data"]


def release(ref):
    return api("PATCH", f"/api/cards/{ref}", {"owners": []})["data"]


def set_status(ref, status):
    return api("PATCH", f"/api/cards/{ref}", {"status": status})["data"]


def set_description(ref, text):
    return api("PATCH", f"/api/cards/{ref}", {"description": text})["data"]


def set_spec(ref, text):
    return api("PATCH", f"/api/cards/{ref}", {"spec": text})["data"]


def set_plan(ref, text):
    return api("PATCH", f"/api/cards/{ref}", {"plan": text})["data"]


def set_branch(ref, name):
    return api("PATCH", f"/api/cards/{ref}", {"branch": name})["data"]


def set_pr_url(ref, url):
    return api("PATCH", f"/api/cards/{ref}", {"pr_url": url})["data"]


def set_sub_tasks(ref, text):
    return api("PATCH", f"/api/cards/{ref}", {"sub_tasks": _parse_sub_tasks(text)})["data"]


def _parse_sub_tasks(text):
    """A JSON array (of strings or {title,done} objects) or newline-per-item text."""
    text = text.strip()
    if text.startswith("["):
        return [{"title": i} if isinstance(i, str) else i for i in json.loads(text)]
    return [{"title": line.strip()} for line in text.splitlines() if line.strip()]


def set_sub_task_done(ref, sub_task_id, done):
    return api("PATCH", f"/api/cards/{ref}/sub-tasks/{sub_task_id}", {"done": done})["data"]


def set_result(ref, text):
    return api("PATCH", f"/api/cards/{ref}", {"ai_result": json.loads(text)})["data"]


def move(ref, stage_name):
    return api("POST", f"/api/cards/{ref}/move", {"stage": resolve_stage_id(stage_name)})["data"]


def create_card(title, stage_name=None, description=None, tag=None):
    body = {"title": title}
    if stage_name is not None:
        body["stage"] = resolve_stage_id(stage_name)
    if description is not None:
        body["description"] = description
    if tag is not None:
        body["tag"] = tag
    return api("POST", "/api/cards", body)["data"]


def comment(ref, text):
    return api("POST", f"/api/cards/{ref}/comments", {"body": text})


def needs_input(ref, question):
    return api("POST", f"/api/cards/{ref}/needs-input", {"question": question})["data"]


# ============================ rendering ============================

def card_line(c):
    return f'{c["ref"]} [{c.get("status", "?")}/{c.get("active_owner") or "-"}] {c["title"]}'


def print_card(c):
    r = c.get("rejection")
    if r:
        date = (r.get("rejected_at") or "")[:10]
        print(f'⚠  CHANGES REQUESTED — sent back to {r.get("to_stage")} '
              f'by {r.get("rejected_by")} ({date})')
        print(f'   {r.get("note", "")}')
        print("   Address this, then redo the stage.\n")
    owners = ", ".join(o.get("name", "?") for o in c.get("owners", []))
    print(f'{c["ref"]}  {c["title"]}')
    print(f'status: {c.get("status", "?")}   active: {c.get("active_owner") or "-"}   owners: {owners}\n')
    print(c.get("description") or "(no description)")
    if c.get("spec"):
        print("\n--- spec ---")
        print(c["spec"])
    for e in c.get("timeline") or []:
        who = e.get("author", {}).get("name", "?")
        if e.get("kind") == "comment":
            print(f"  - {who}: {e.get('body', '')}")
        else:
            print(f"  * {who} {e.get('type', '')} {e.get('meta', '')}")


def emit(args, data, human):
    print(json.dumps(data, indent=2) if getattr(args, "json", False) else human)


# ============================ CLI commands ============================

def cmd_board(args):
    b = get_board()
    if args.json:
        return print(json.dumps(b, indent=2))
    by_stage = {}
    for c in b["cards"]:
        by_stage.setdefault(c["stage_id"], []).append(c)
    print(f'{b["board"]["name"]} ({b["board"]["key"]})\n')
    for s in b["stages"]:
        print(f'{s["name"]} ({s["type"]})')
        for c in by_stage.get(s["id"], []) or []:
            print("  " + card_line(c))
        if not by_stage.get(s["id"]):
            print("  (empty)")
        print()


def cmd_card(args):
    c = get_card(args.ref)
    print(json.dumps(c, indent=2)) if args.json else print_card(c)


def cmd_create(args):
    card = create_card(
        args.title,
        stage_name=args.stage,
        description=read_arg(args.description) if args.description is not None else None,
        tag=args.tag,
    )
    print(json.dumps(card, indent=2)) if args.json else print_card(card)


def _simple(fn):
    """Wrap a mutation returning a card into a CLI handler that prints it."""
    def run(args):
        card = fn(args)
        emit(args, card, card_line(card))
    return run


def cmd_reject(args):
    body = {"note": read_arg(args.note)}
    if getattr(args, "to", None):
        body["to"] = args.to
    card = api("POST", f"/api/cards/{args.ref}/reject", body)["data"]
    emit(args, card, card_line(card))


def cmd_comment(args):
    comment(args.ref, read_arg(args.text))
    print(f"{args.ref}: comment posted")


def cmd_layout(args):
    """Print a relay_config.json pipeline skeleton derived from the live board."""
    b = get_board()
    ai = [s for s in b["stages"] if s.get("ai_enabled")]
    print(json.dumps({"poll_interval": 45, "pipeline": [
        {"stage": s["name"], "from": "<column left of it>", "done": "<its Review/Done sub-stage>",
         "action": [{"claude": "<what to do for {ref}>"}]} for s in ai
    ]}, indent=2))


# ============================ the runner ============================

def load_config():
    return json.load(open(CONFIG_PATH))


def fingerprint(b):
    rows = sorted(f'{c["ref"]}|{c["stage_id"]}|{c.get("status")}|{c.get("active_owner")}' for c in b["cards"])
    return hashlib.sha256("\n".join(rows).encode()).hexdigest()


def blocked(card):
    return card.get("status") == "needs_input"


def find_ready(b, cfg):
    """(card, entry, mode) for the next card to work — right-to-left priority; resume before fresh."""
    by_name = {s["name"]: s for s in b["stages"]}
    by_id = {}
    for c in b["cards"]:
        by_id.setdefault(c["stage_id"], []).append(c)

    # main stage id -> [its sub-lane stage ids], so a WIP limit counts its whole column
    children = {}
    for s in b["stages"]:
        parent = s.get("parent_id")
        if parent is not None:
            children.setdefault(parent, []).append(s["id"])

    def cards_in(name):
        s = by_name.get(name)
        return by_id.get(s["id"], []) if s else []

    def used(name):
        s = by_name.get(name)
        if not s:
            return 0
        total = len(by_id.get(s["id"], []))
        for child_id in children.get(s["id"], []):
            total += len(by_id.get(child_id, []))
        return total

    def wip_ok(name):
        s = by_name.get(name)
        limit = s.get("wip_limit") if s else None
        return not limit or used(name) < limit

    for entry in reversed(cfg["pipeline"]):
        for c in cards_in(entry["stage"]):
            if c.get("status") == "working" and not blocked(c):
                return c, entry, "resume"
        if wip_ok(entry["stage"]):
            for c in cards_in(entry["from"]):
                if not blocked(c):
                    return c, entry, "fresh"
    return None


def slug(text):
    return re.sub(r"[^a-z0-9]+", "-", text.lower()).strip("-")[:40] or "card"


def render(template, vars):
    for k, v in vars.items():
        template = template.replace("{" + k + "}", str(v))
    return template


def _print_claude_event(ev):
    """Render one stream-json event from a headless claude as a readable feed line."""
    t = ev.get("type")
    if t == "assistant":
        for b in ev.get("message", {}).get("content", []):
            if b.get("type") == "text" and b.get("text", "").strip():
                print("    🤖 " + b["text"].strip()[:600], flush=True)
            elif b.get("type") == "tool_use":
                inp = b.get("input", {}) or {}
                brief = (inp.get("command") or inp.get("file_path") or inp.get("path")
                         or inp.get("pattern") or inp.get("description") or "")
                print(f"    🔧 {b.get('name')}  {str(brief)[:140]}", flush=True)
    elif t == "result":
        turns = ev.get("num_turns")
        print(f"    {'✗' if ev.get('is_error') else '✓'} claude finished"
              + (f" ({turns} turns)" if turns else ""), flush=True)


def _stream_claude(prompt):
    """Run headless claude with a live streamed feed. Returns True on success.
    --dangerously-skip-permissions lets it use tools unattended (this is an autonomous
    runner); --output-format stream-json emits one event per step, streamed here."""
    cmd = ["claude", "-p", prompt, "--dangerously-skip-permissions",
           "--verbose", "--output-format", "stream-json"]
    # `claude -p` caps how long it waits for a background workflow at 10 minutes
    # by default (CLAUDE_CODE_PRINT_BG_WAIT_CEILING_MS, v2.1.182+). /exec-plan runs
    # far longer than that, so without lifting the cap -p exits mid-run and the
    # stage ships a PARTIAL plan as if it were done. "0" = wait until the workflow
    # finishes on its own (it is internally bounded). An explicit env override wins.
    env = dict(os.environ)
    env.setdefault("CLAUDE_CODE_PRINT_BG_WAIT_CEILING_MS", "0")
    proc = subprocess.Popen(cmd, cwd=ROOT, text=True, bufsize=1, env=env,
                            stdout=subprocess.PIPE, stderr=subprocess.STDOUT)
    for line in proc.stdout:
        line = line.strip()
        if not line:
            continue
        try:
            _print_claude_event(json.loads(line))
        except Exception:
            print("    " + line[:200], flush=True)
    return proc.wait() == 0


def run_step(step, vars):
    """A pipeline step is {shell: cmd} or {claude: prompt}. Returns True on success."""
    if "shell" in step:
        cmd = render(step["shell"], vars)
        if DRY:
            log(f"  (dry) shell: {cmd}")
            return True
        return subprocess.run(cmd, shell=True, cwd=ROOT).returncode == 0
    if "claude" in step:
        prompt = render(step["claude"], vars)
        if DRY:
            log("  (dry) claude -p <<<\n" + "\n".join("      " + l for l in prompt.splitlines()))
            return True
        return _stream_claude(prompt)
    log(f"  ! unknown step: {step}")
    return False


def flag(ref, reason):
    log(f"  ⚑ {ref}: {reason}")
    if not DRY:
        try:
            needs_input(ref, f"[auto] stage failed: {reason}. A human needs to look — the runner "
                             f"won't retry until this is cleared.")
        except SystemExit:
            pass


def work(card, entry, mode):
    ref = card["ref"]
    n = ref.split("-")[-1]
    vars = {"ref": ref, "title": card["title"], "stage": entry["stage"], "from": entry["from"],
            "done": entry["done"],
            "branch": card.get("branch") or f"rly-{n}-{slug(card['title'])}",
            "pr_url": card.get("pr_url") or "",
            "relay": HERE, "url": os.environ.get("RELAY_URL", "")}
    banner([
        f"→ {ref}  {card['title']}",
        f"{entry['stage']} ({mode}) — then {entry['done']}",
    ])
    if DRY:
        for step in entry["action"]:
            run_step(step, vars)
        return
    own(ref)
    if mode == "fresh":
        move(ref, entry["stage"])
    set_status(ref, "working")
    ok = all(run_step(step, vars) for step in entry["action"])
    after = get_card(ref)
    if after.get("status") == "needs_input":
        return log(f"  {ref} asked the human — left blocked in {entry['stage']}")
    if not ok:
        return flag(ref, f"{entry['stage']} stage did not complete")
    comment(ref, f"{entry['stage']} done → pushing to {entry['done']}")
    move(ref, entry["done"])
    set_status(ref, "in_review" if entry["done"].lower().endswith(":review") else "queued")
    release(ref)
    log(f"  ✓ {ref} pushed to {entry['done']}")


def state_load():
    try:
        return json.load(open(STATE_PATH))
    except Exception:
        return {}


def state_save(fingerprint, version):
    if not DRY:
        json.dump({"fingerprint": fingerprint, "version": version}, open(STATE_PATH, "w"))


def tick(cfg):
    saved = state_load()
    version = get_board_version()
    # Cheap outer gate: when the server exposes a version and it hasn't moved
    # since we last looked, skip the full-board fetch entirely.
    if version is not None and version == saved.get("version"):
        return False

    b = get_board()
    fp = fingerprint(b)
    # Precise inner gate: a version bump that didn't change readiness (e.g. a
    # comment) still short-circuits here before we scan for work.
    if fp == saved.get("fingerprint"):
        state_save(fp, version)
        return False

    log("board changed — scanning for ready work")
    ready = find_ready(b, cfg)
    if not ready:
        log("  nothing ready to work")
        state_save(fp, version)
        return False

    work(*ready)
    state_save(None, None)  # after real work, force a full re-poll next tick
    return True


def cmd_watch(args):
    global DRY
    DRY = args.dry_run
    cfg = load_config()
    interval = args.interval or cfg.get("poll_interval", 45)
    env("RELAY_URL"), env("RELAY_API_KEY")
    log(f"watching {os.environ['RELAY_URL']} every {interval}s"
        + (" (dry-run)" if DRY else "") + (" — one pass" if args.once else ""))
    while True:
        did = tick(cfg)
        if args.once:
            break
        if not did:
            time.sleep(interval)


# ============================ argparse ============================

def build_parser():
    p = argparse.ArgumentParser(prog="relay", description=__doc__.splitlines()[1])
    sub = p.add_subparsers(dest="cmd")

    def add(name, fn, *pos, json_flag=False):
        sp = sub.add_parser(name)
        for a in pos:
            sp.add_argument(a)
        if json_flag:
            sp.add_argument("--json", action="store_true")
        sp.set_defaults(func=fn)
        return sp

    add("board", cmd_board, json_flag=True)
    add("card", cmd_card, "ref", json_flag=True)
    c = add("create", cmd_create, "title", json_flag=True)
    c.add_argument("--stage")
    c.add_argument("--description")
    c.add_argument("--tag")
    add("pull", cmd_pull, json_flag=True)
    add("move", _simple(lambda a: move(a.ref, a.stage)), "ref", "stage", json_flag=True)
    add("status", _simple(lambda a: set_status(a.ref, a.status)), "ref", "status", json_flag=True)
    add("describe", _simple(lambda a: set_description(a.ref, read_arg(a.text))), "ref", "text", json_flag=True)
    add("spec", _simple(lambda a: set_spec(a.ref, read_arg(a.text))), "ref", "text", json_flag=True)
    add("plan", _simple(lambda a: set_plan(a.ref, read_arg(a.text))), "ref", "text", json_flag=True)
    add("branch", _simple(lambda a: set_branch(a.ref, a.name)), "ref", "name", json_flag=True)
    add("pr", _simple(lambda a: set_pr_url(a.ref, a.url)), "ref", "url", json_flag=True)
    add("sub-tasks", _simple(lambda a: set_sub_tasks(a.ref, read_arg(a.text))), "ref", "text", json_flag=True)
    add("check", _simple(lambda a: set_sub_task_done(a.ref, a.id, True)), "ref", "id", json_flag=True)
    add("uncheck", _simple(lambda a: set_sub_task_done(a.ref, a.id, False)), "ref", "id", json_flag=True)
    add("result", _simple(lambda a: set_result(a.ref, read_arg(a.text))), "ref", "text", json_flag=True)
    add("needs-input", _simple(lambda a: needs_input(a.ref, read_arg(a.question))), "ref", "question", json_flag=True)
    add("own", _simple(lambda a: own(a.ref)), "ref", json_flag=True)
    add("release", _simple(lambda a: release(a.ref)), "ref", json_flag=True)
    add("approve", _simple(lambda a: api("POST", f"/api/cards/{a.ref}/approve", {})["data"]), "ref", json_flag=True)
    rj = add("reject", cmd_reject, "ref", "note", json_flag=True)
    rj.add_argument("--to")
    add("comment", cmd_comment, "ref", "text")
    add("layout", cmd_layout)
    w = add("watch", cmd_watch)
    w.add_argument("--once", action="store_true")
    w.add_argument("--dry-run", action="store_true")
    w.add_argument("--interval", type=int)
    return p


def cmd_pull(args):
    """Advisory: print the next ready card per the config (does not move it)."""
    ready = find_ready(get_board(), load_config())
    if not ready:
        return emit(args, None, "No card ready to pull.")
    c, entry, _ = ready
    emit(args, {"card": c, "target_stage": entry["stage"]},
         f'{card_line(c)}  → ready for {entry["stage"]}')


def main():
    args = build_parser().parse_args()
    if not getattr(args, "cmd", None):
        # no arguments → run the board runner with defaults
        ns = argparse.Namespace(once=False, dry_run=False, interval=None)
        return cmd_watch(ns)
    args.func(args)


if __name__ == "__main__":
    main()
