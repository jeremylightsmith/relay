#!/usr/bin/env python3
"""relay — one tool for a Relay board: a REST-API CLI, and (with `relay execute`) the
board *executor* that claims node-jobs from the server and runs them.

This file is generic: it knows the Relay REST API and how to execute node-jobs, but
NOTHING about any particular board's columns, agents, or skills. All of that lives
server-side as flow data (ADR 0006) — the executor just runs the node it is handed.

Config (env): RELAY_URL, RELAY_API_KEY  (a board key from /board/settings)
Executor-local config: .relay/executor.json (worktree namespace + capacity)

  relay execute [--once] [--dry-run] [--interval N]   # the executor
  relay init [--url URL] [--force] [--dry-run] [--no-self-update]   # scaffold a project
  relay board [--json]        relay card REF [--json]
  relay why REF [--json]      # why isn't this card moving? — one plain-language answer
  relay runs REF [--json]     # the card's runs + node executions, detail untruncated
  relay executors [--json]    # who is connected, their capacity, and the jobs they hold
  relay comment REF TEXT      relay move REF STAGE        relay status REF STATUS
  relay create TITLE [--stage N]  relay describe REF TEXT   relay needs-input REF [Q] [--questions @file]
  relay own REF / release REF relay approve REF           relay reject REF NOTE
  relay sub-tasks REF @file   relay check REF ID / uncheck REF ID   relay result REF @file
  relay criteria REF @file    # acceptance criteria (numbered, authored at Spec)
  relay attach REF FILE [--caption TEXT] [--json]
  relay tag REF [VALUE]       # set the card's tag (omit VALUE to clear)

TEXT/Q/NOTE accept "-" (stdin) or "@path" (file). --json for machine output.
"""
import argparse
import base64
import collections
import difflib
import hashlib
import json
import mimetypes
import os
import queue
import re
import shutil
import signal
import socket
import subprocess
import sys
import tempfile
import threading
import time
import urllib.error
import urllib.request

HERE = os.path.abspath(__file__)
ROOT = os.path.dirname(os.path.dirname(HERE))
EXECUTOR_CONFIG_PATH = os.path.join(ROOT, ".relay", "executor.json")
DRY = False
FORWARDER = None
RUN_IDS = {}   # ref -> run_id of the run currently working it (RLY-112)
NODE_JOB_IDS = {}   # ref -> node_job_id currently running it (executor mode, RLY-135)

# ---- executor version (RLY-184) ----
#
# `bin/relay` is loaded into memory at process start, so a long-running `relay execute` keeps
# serving whatever version it started with — forever, and silently — no matter how many times
# this file is fixed and merged underneath it. Three cards died that way before anyone noticed.
# So the executor DECLARES a version on every claim and heartbeat, the server declares the
# minimum it will work with, and anything below that is refused work and visibly marked.
#
# Bump EXECUTOR_VERSION on ANY change to this file and paste the new fingerprint below;
# bin/test_relay.py's ExecutorFingerprintGuardTest enforces it and prints the value to paste.
EXECUTOR_VERSION = 5
EXECUTOR_FINGERPRINT = "32e4b922088da2badb6f475a67fdda261ecc991b4398f358558d5fd34f1b6149"

# The two constant lines above are masked out of the hash: satisfying the guard (bump the
# integer, paste the fingerprint) must not itself re-break it. Everything else in the file is
# covered, so no behaviour change can slip through without a deliberate bump.
FINGERPRINT_MASK = re.compile(r"(?m)^(EXECUTOR_VERSION|EXECUTOR_FINGERPRINT)\s*=.*$")


def executor_fingerprint(source=None):
    """sha256 of this file with the two version constants masked out (RLY-184).

    No git dependency, so it behaves identically in a worktree, on a detached HEAD, or in CI."""
    if source is None:
        with open(HERE, encoding="utf-8") as f:
            source = f.read()
    masked = FINGERPRINT_MASK.sub(r"\1 = <masked>", source)
    return hashlib.sha256(masked.encode()).hexdigest()


def executor_ident(cfg):
    """The `executor` dict on the wire, shared by claim_node_job and heartbeat_body (RLY-184).

    Pure and named so bin/test_relay.py can pin `version` against
    test/fixtures/executor_contract.json the same way outcome_body/heartbeat_body are pinned."""
    return {"name": cfg["name"], "host": socket.gethostname(), "version": EXECUTOR_VERSION}


def die(msg):
    print(f"relay: {msg}", file=sys.stderr)
    sys.exit(1)


def log(msg, *, ref=None, kind="lifecycle"):
    print(f"[relay] {msg}", flush=True)
    forward(kind, msg, ref)


# ============================ REST API client ============================

def env(name):
    v = os.environ.get(name)
    return v or die(f"{name} is not set")


API_MAX_ATTEMPTS = 3  # one initial try + up to two retries


def _api_backoff(attempt):
    """Sleep before retry `attempt` (1-based): 0.5s, then 1s. Isolated in a named
    helper so tests can monkeypatch it to a no-op and not actually wait."""
    time.sleep(0.5 * 2 ** (attempt - 1))


def _retryable(method, err):
    """Whether a failed attempt with this HTTP method should be retried.

    URLError (not an HTTPError): the server never processed the request, so a retry
    can't double-apply — safe for any method. HTTPError 5xx: retry only idempotent
    methods (GET, PATCH), never POST (could double-apply a mutation). 4xx: never."""
    if isinstance(err, urllib.error.HTTPError):
        return err.code >= 500 and method in ("GET", "PATCH")
    return isinstance(err, urllib.error.URLError)


def api(method, path, body=None, soft_404=False, soft_conflict=False, timeout=None):
    url = env("RELAY_URL").rstrip("/") + path
    data = json.dumps(body).encode() if body is not None else None
    req = urllib.request.Request(url, data=data, method=method)
    req.add_header("Authorization", f"Bearer {env('RELAY_API_KEY')}")
    if data is not None:
        req.add_header("Content-Type", "application/json")
    # Pass a read timeout only when asked (the long-poll claim): a bare urlopen keeps the
    # prior global-default behavior for every existing call, byte for byte.
    open_kwargs = {} if timeout is None else {"timeout": timeout}
    for attempt in range(1, API_MAX_ATTEMPTS + 1):
        try:
            with urllib.request.urlopen(req, **open_kwargs) as resp:
                raw = resp.read()
                return json.loads(raw) if raw else {}
        except socket.timeout:
            raise   # long-poll read timeout — the claim caller treats it as 'no work'
        except urllib.error.HTTPError as e:
            if soft_404 and e.code == 404:
                return None
            if soft_conflict and e.code == 409:
                # A verdict, not a transient error (RLY-184): hand the body to the caller
                # rather than die()ing into the loop's generic retry.
                try:
                    return json.loads(e.read())
                except Exception:
                    return {"error": {"code": "conflict"}}
            if attempt < API_MAX_ATTEMPTS and _retryable(method, e):
                log(f"API {e.code} on {method} {path}, retrying "
                    f"({attempt}/{API_MAX_ATTEMPTS - 1})", kind="error")
                _api_backoff(attempt)
                continue
            try:
                msg = json.loads(e.read())["error"]["message"]
            except Exception:
                msg = f"HTTP {e.code}"
            die(f"API {e.code}: {msg}")
        except urllib.error.URLError as e:
            if attempt < API_MAX_ATTEMPTS and _retryable(method, e):
                log(f"request failed ({e.reason}) on {method} {path}, retrying "
                    f"({attempt}/{API_MAX_ATTEMPTS - 1})", kind="error")
                _api_backoff(attempt)
                continue
            die(f"request failed: {e.reason}")


def _ref_from_tag(tag):
    """Extract 'RLY-7' from a per-card feed tag like '[RLY-7] '; None if untagged."""
    m = re.match(r"\[([^\]]+)\]", tag or "")
    return m.group(1) if m else None


def forward(kind, text, ref=None):
    """Best-effort: hand one feed line to the background mirror, if one is running."""
    if FORWARDER is not None:
        FORWARDER.enqueue(kind, text, ref, RUN_IDS.get(ref), NODE_JOB_IDS.get(ref))


class LogForwarder:
    """Background thread mirroring the runner feed to POST /api/board/logs.

    Best-effort by construction: enqueue() never blocks (drops when the bounded
    queue is full) and _send() swallows every error — including api()'s die()
    (SystemExit) — so the log path can never raise into or stall work()."""

    def __init__(self, flush_interval=0.25, batch_size=50, max_queue=1000):
        self.q = queue.Queue(maxsize=max_queue)
        self.flush_interval = flush_interval
        self.batch_size = batch_size
        self._stop = threading.Event()
        self._thread = threading.Thread(target=self._run, daemon=True)

    def start(self):
        self._thread.start()

    def stop(self):
        self._stop.set()

    def enqueue(self, kind, text, ref=None, run_id=None, node_job_id=None):
        item = {"kind": kind, "ref": ref, "text": text, "run_id": run_id}
        if node_job_id is not None:
            item["node_job_id"] = node_job_id
        try:
            self.q.put_nowait(item)
        except queue.Full:
            pass

    def _drain(self):
        batch = []
        try:
            batch.append(self.q.get(timeout=self.flush_interval))
        except queue.Empty:
            return batch
        while len(batch) < self.batch_size:
            try:
                batch.append(self.q.get_nowait())
            except queue.Empty:
                break
        return batch

    def _send(self, batch):
        try:
            api("POST", "/api/board/logs", batch)
        except SystemExit:  # api() die()s on HTTP/network error
            pass
        except Exception:
            pass

    def _run(self):
        while not self._stop.is_set():
            batch = self._drain()
            if batch:
                self._send(batch)


# Agent names the Claude CLI provides itself rather than as a file on disk. Best-effort
# allowlist that tracks the CLI: its only failure mode is a MISSED warning (an agent we
# forgot to list here would be reported missing), never a false alarm about a real agent.
BUILTIN_AGENTS = {"general-purpose", "Explore", "Plan", "claude", "statusline-setup"}


def _md_stems(directory):
    """File stems of `<directory>/*.md`. A missing directory contributes nothing."""
    try:
        names = os.listdir(directory)
    except OSError:
        return []
    return [n[:-len(".md")] for n in names if n.endswith(".md")]


def _skill_dirs(directory):
    """Names of `<directory>/*/SKILL.md` skill directories. A directory without a SKILL.md
    is not a skill — the name would not resolve."""
    try:
        names = os.listdir(directory)
    except OSError:
        return []
    return [n for n in names if os.path.isfile(os.path.join(directory, n, "SKILL.md"))]


def collect_capabilities():
    """What this executor can actually resolve BY NAME — the question only the executor can
    answer, since the server never sees its filesystem (RLY-182).

    Scans the repo checkout AND the user-level ~/.claude, so a developer with agents
    installed globally is not reported as missing them. Two different directories back a
    slash command: `.claude/skills/<name>/SKILL.md` and `.claude/commands/<name>.md` —
    /write-plan lives ONLY in commands/ on this very repo, so a resolver that checked
    skills/ alone would report the Plan flow broken here."""
    homes = [os.path.join(ROOT, ".claude"), os.path.expanduser("~/.claude")]
    agents, skills = set(BUILTIN_AGENTS), set()
    for home in homes:
        agents.update(_md_stems(os.path.join(home, "agents")))
        skills.update(_skill_dirs(os.path.join(home, "skills")))
        skills.update(_md_stems(os.path.join(home, "commands")))
    return {"agents": sorted(agents), "skills": sorted(skills)}


def capabilities_hash(capabilities):
    """Stable digest of an inventory, so the beat can send only on change."""
    blob = json.dumps(capabilities, sort_keys=True).encode("utf-8")
    return hashlib.sha256(blob).hexdigest()


class ExecutorHeartbeat:
    """Per-executor heartbeat for `relay execute`. POSTs
    {executor, capacity, running:[job-ids]} to /api/node-jobs/heartbeat every `interval`s and
    READS the response's revoked job-ids, handing each to `on_revoke` (§5).

    This is the ONLY way an executor announces itself (RLY-164). It carries two things the
    pull model has no other channel for:

      * `capacity` — the CONFIGURED per-class totals (cfg["capacity"]), never
        ExecutorPool.capacity()'s live free count. Relay.Runs.Capacity is what the scheduler
        reads to decide whether to dispatch, it is lost on every app restart (hence a
        REPEATING beat, not a one-shot at startup), and Scheduler.Server debits in-flight
        :running runs server-side — so sending the decremented count would double-debit every
        running run.
      * the reply's revoked ids — how taking the baton (ADR 0004) or cancelling from the run
        panel actually stops a live agent, instead of the executor finding out on its next
        outcome POST 20+ minutes later.
      * `capabilities` — the agents and skills this machine can resolve by name, sent on
        startup and whenever the inventory changes (never on every beat). It is what
        Relay.Runs.preflight_flow/1 reads to tell a human whether enabling a flow will
        actually work, before the first card moves.

    Best-effort by construction: swallows api()'s die() (SystemExit) and any other error, so a
    heartbeat can never stall or raise into a job. soft_404 is kept as belt-and-braces for an
    executor pointed at an older server, but the route now exists."""

    def __init__(self, executor, running_fn, on_revoke, interval=15, capacity=None):
        self.executor = executor
        self.running_fn = running_fn
        self.on_revoke = on_revoke
        self.interval = interval
        self.capacity = capacity or {}
        # Last inventory hash the server ACKNOWLEDGED. None ⇒ send on the next beat, so the
        # first beat after startup always carries it.
        self._caps_hash = None
        self._stop = threading.Event()
        self._thread = threading.Thread(target=self._run, daemon=True)

    def start(self):
        self._thread.start()

    def stop(self):
        self._stop.set()

    def _beat(self):
        # A handful of listdir calls at the 15s interval — negligible, and it means a skill
        # or agent added mid-session is reported without restarting the executor.
        capabilities = collect_capabilities()
        digest = capabilities_hash(capabilities)
        send = capabilities if digest != self._caps_hash else None
        try:
            resp = api("POST", "/api/node-jobs/heartbeat",
                       heartbeat_body(self.executor, self.capacity, self.running_fn(), send),
                       soft_404=True) or {}
            # Only a SUCCESSFUL post advances the stored hash: a failed POST must leave it
            # alone so the next beat retries.
            if send is not None:
                self._caps_hash = digest
            # The server holds no inventory for this row (recreated row, or an executor
            # predating RLY-182). Forget what we think it knows and resend next beat —
            # without this nudge a recreated row shows a permanent, FALSE "missing agents".
            if resp.get("want_capabilities"):
                self._caps_hash = None
            for job_id in resp.get("revoked", []):
                self.on_revoke(job_id)
        except SystemExit:      # api() die()s on HTTP/network error
            pass
        except Exception:
            pass

    def _run(self):
        while not self._stop.wait(self.interval):
            self._beat()


def read_arg(text):
    if text == "-":
        return sys.stdin.read()
    if text.startswith("@"):
        with open(text[1:], encoding="utf-8") as f:
            return f.read()
    return text


def get_board():
    return api("GET", "/api/board")


def get_card(ref):
    return api("GET", f"/api/cards/{ref}")["data"]


def resolve_stage_id(name, board=None):
    board = board or get_board()
    for s in board["stages"]:
        if s["name"] == name:
            return s["id"]
    die(f'no stage named "{name}". stages: ' + ", ".join(s["name"] for s in board["stages"]))


# board mutations (used by both the CLI and the runner)
def own(ref):
    return api("PATCH", f"/api/cards/{ref}", {"owners": ["agent"]})["data"]


def release(ref):
    return api("PATCH", f"/api/cards/{ref}", {"owners": []})["data"]


def set_status(ref, status):
    return api("PATCH", f"/api/cards/{ref}", {"status": status})["data"]


def set_description(ref, text):
    return api("PATCH", f"/api/cards/{ref}", {"description": text})["data"]


def set_acceptance_criteria(ref, text):
    return api("PATCH", f"/api/cards/{ref}", {"acceptance_criteria": text})["data"]


def set_spec(ref, text):
    return api("PATCH", f"/api/cards/{ref}", {"spec": text})["data"]


def set_plan(ref, text):
    return api("PATCH", f"/api/cards/{ref}", {"plan": text})["data"]


def set_branch(ref, name):
    return api("PATCH", f"/api/cards/{ref}", {"branch": name})["data"]


def set_pr_url(ref, url):
    return api("PATCH", f"/api/cards/{ref}", {"pr_url": url})["data"]


def set_tag(ref, value):
    return api("PATCH", f"/api/cards/{ref}", {"tag": value or None})["data"]


def set_sub_tasks(ref, text):
    return api("PATCH", f"/api/cards/{ref}", {"sub_tasks": _parse_sub_tasks(text)})["data"]


def _parse_sub_tasks(text):
    """A JSON array (of strings or {title,done} objects) or newline-per-item text."""
    text = text.strip()
    if text.startswith("["):
        return [{"title": i} if isinstance(i, str) else i for i in json.loads(text)]
    return [{"title": line.strip()} for line in text.splitlines() if line.strip()]


def set_sub_task_done(ref, sub_task_id, done):
    return api("PATCH", f"/api/cards/{ref}/sub-tasks/{sub_task_id}", {"done": done})["data"]


def set_result(ref, text):
    return api("PATCH", f"/api/cards/{ref}", {"ai_result": json.loads(text)})["data"]


def move(ref, stage_name):
    return api("POST", f"/api/cards/{ref}/move", {"stage": resolve_stage_id(stage_name)})["data"]


def create_card(title, stage_name=None, description=None, tag=None):
    body = {"title": title}
    if stage_name is not None:
        body["stage"] = resolve_stage_id(stage_name)
    if description is not None:
        body["description"] = description
    if tag is not None:
        body["tag"] = tag
    return api("POST", "/api/cards", body)["data"]


def comment(ref, text):
    return api("POST", f"/api/cards/{ref}/comments", {"body": text})


def attach(ref, path):
    with open(path, "rb") as f:
        data = f.read()
    content_type = mimetypes.guess_type(path)[0] or "application/octet-stream"
    body = {
        "filename": os.path.basename(path),
        "content_type": content_type,
        "data_base64": base64.b64encode(data).decode(),
    }
    return api("POST", f"/api/cards/{ref}/attachments", body)["data"]


def needs_input_body(question, questions_raw):
    """POST body for needs-input: {"question": ...} for a plain ask, or a validated
    {"questions": [...]} from the JSON in questions_raw (already resolved from @file/stdin)."""
    if questions_raw is None:
        return {"question": question}
    try:
        parsed = json.loads(questions_raw)
    except json.JSONDecodeError as e:
        die(f"--questions is not valid JSON: {e}")
    if not isinstance(parsed, list) or not parsed:
        die("--questions must be a non-empty JSON array of question objects")
    return {"questions": parsed}


def needs_input(ref, question=None, questions_raw=None):
    body = needs_input_body(question, questions_raw)
    return api("POST", f"/api/cards/{ref}/needs-input", body)["data"]


# ============================ rendering ============================

def card_line(c):
    return f'{c["ref"]} [{c.get("status", "?")}/{c.get("active_owner") or "-"}] {c["title"]}'


def print_card(c):
    r = c.get("rejection")
    if r:
        date = (r.get("rejected_at") or "")[:10]
        print(f'⚠  CHANGES REQUESTED — sent back to {r.get("to_stage")} '
              f'by {r.get("rejected_by")} ({date})')
        print(f'   {r.get("note", "")}')
        print("   Address this, then redo the stage.\n")
    owners = ", ".join(o.get("name", "?") for o in c.get("owners", []))
    print(f'{c["ref"]}  {c["title"]}')
    line = f'status: {c.get("status", "?")}   active: {c.get("active_owner") or "-"}   owners: {owners}'
    if c.get("tag"):
        line += f'   tag: #{c["tag"]}'
    print(line + "\n")
    print(c.get("description") or "(no description)")
    if c.get("acceptance_criteria"):
        print("\n--- acceptance criteria ---")
        print(c["acceptance_criteria"])
    if c.get("spec"):
        print("\n--- spec ---")
        print(c["spec"])
    for e in c.get("timeline") or []:
        who = e.get("author", {}).get("name", "?")
        if e.get("kind") == "comment":
            print(f"  - {who}: {e.get('body', '')}")
        else:
            print(f"  * {who} {e.get('type', '')} {e.get('meta', '')}")


def print_why(d):
    """The prose answer to "why isn't this card moving?" — one or two sentences, never a
    JSON dump. `--json` is there for the full structure; this is what a human reads."""
    print(f'{d.get("verdict", "?")}: {d.get("detail", "")}'.rstrip())
    last = (d.get("evidence") or {}).get("last_execution") or {}
    if last.get("detail"):
        print(f'\n--- {last.get("node_key", "?")} ({last.get("outcome", "?")}) ---')
        print(last["detail"])


def indent(text, prefix):
    return "\n".join(prefix + line for line in text.splitlines())


def format_runs(runs):
    """The card's runs and every node execution, with detail printed IN FULL — truncating
    it is what sent an operator to `fly ssh console` in the first place (RLY-177)."""
    out = []
    for r in runs:
        out.append(f'run {r.get("id")}  {r.get("flow_key", "?")}  [{r.get("status", "?")}]'
                   f'  node: {r.get("current_node") or "-"}'
                   f'  {r.get("started_at") or ""} → {r.get("finished_at") or "…"}')
        for e in r.get("node_executions") or []:
            out.append(f'  - {e.get("node_key", "?")} '
                       f'(visit {e.get("visit", "?")}, attempt {e.get("attempt", "?")}) '
                       f'→ {e.get("outcome") or "running"}')
            if e.get("detail"):
                out.append(indent(e["detail"], "      "))
        if r.get("failure_detail"):
            out.append("  failure_detail:")
            out.append(indent(r["failure_detail"], "      "))
    return "\n".join(out) if out else "(no runs)"


def format_executors(executors):
    out = []
    for e in executors:
        caps = " ".join(f"{k}={v}" for k, v in sorted((e.get("capacity") or {}).items()))
        flag = "  STALE" if e.get("stale?") else ""
        out.append(f'{e.get("name", "?")} @ {e.get("host") or "?"}  {caps}  '
                   f'heartbeat: {e.get("last_heartbeat") or "never"}{flag}')
        for j in e.get("jobs") or []:
            out.append(f'  - job {j.get("id")} {j.get("ref", "?")} {j.get("node_key", "?")} [{j.get("state", "?")}]')
    return "\n".join(out) if out else "(no executors connected)"


def emit(args, data, human):
    print(json.dumps(data, indent=2) if getattr(args, "json", False) else human)


# ============================ CLI commands ============================

def cmd_board(args):
    path = "/api/board?include_done=1" if getattr(args, "include_done", False) else "/api/board"
    b = api("GET", path)
    if args.json:
        return print(json.dumps(b, indent=2))
    by_stage = {}
    for c in b["cards"]:
        by_stage.setdefault(c["stage_id"], []).append(c)
    print(f'{b["board"]["name"]} ({b["board"]["key"]})\n')
    for s in b["stages"]:
        print(f'{s["name"]} ({s["type"]})')
        for c in by_stage.get(s["id"], []) or []:
            print("  " + card_line(c))
        if not by_stage.get(s["id"]):
            print("  (empty)")
        print()


def cmd_card(args):
    c = get_card(args.ref)
    print(json.dumps(c, indent=2)) if args.json else print_card(c)


def cmd_why(args):
    d = api("GET", f"/api/cards/{args.ref}/diagnosis")["data"]
    if getattr(args, "json", False):
        print(json.dumps(d, indent=2))
    else:
        print_why(d)


def cmd_retry(args):
    """Re-enter a terminally failed run at the node that died (RLY-189).

    The server refuses with a 422 whose message names the reason; api() turns that
    into a die() — a silent success on a refused retry is the failure mode this
    command exists to prevent."""
    body = {"at": args.at} if getattr(args, "at", None) else {}
    d = api("POST", f"/api/cards/{args.ref}/retry", body)["data"]
    if getattr(args, "json", False):
        print(json.dumps(d, indent=2))
    else:
        log(f"{args.ref}: run {d['run_id']} re-entered at {d['node']} "
            f"(retry {d['retries']})")


def cmd_runs(args):
    runs = api("GET", f"/api/cards/{args.ref}/runs")["data"]
    emit(args, runs, format_runs(runs))


def cmd_executors(args):
    executors = api("GET", "/api/executors")["data"]
    emit(args, executors, format_executors(executors))


def cmd_create(args):
    card = create_card(
        args.title,
        stage_name=args.stage,
        description=read_arg(args.description) if args.description is not None else None,
        tag=args.tag,
    )
    print(json.dumps(card, indent=2)) if args.json else print_card(card)


def _simple(fn):
    """Wrap a mutation returning a card into a CLI handler that prints it."""
    def run(args):
        card = fn(args)
        emit(args, card, card_line(card))
    return run


def cmd_reject(args):
    card = api("POST", f"/api/cards/{args.ref}/reject", {"note": read_arg(args.note)})["data"]
    emit(args, card, card_line(card))


def cmd_needs_input(args):
    question = read_arg(args.question) if args.question is not None else None
    questions_raw = read_arg(args.questions) if args.questions is not None else None
    if question is None and questions_raw is None:
        die("needs-input needs a QUESTION argument or --questions")
    card = needs_input(args.ref, question, questions_raw)
    emit(args, card, card_line(card))


def cmd_comment(args):
    comment(args.ref, read_arg(args.text))
    print(f"{args.ref}: comment posted")


def cmd_attach(args):
    data = attach(args.ref, args.file)
    # --caption rewrites the alt text client-side; otherwise use the server's snippet.
    md = f"![{args.caption}]({data['url']})" if args.caption else data["markdown"]
    emit(args, {**data, "markdown": md}, md)


# ============================ the executor ============================

def load_executor_config():
    """Executor-local config from .relay/executor.json. Missing file → sensible defaults;
    capacity is the only field a developer routinely edits (ADR 0006, table 1)."""
    defaults = {
        "name": socket.gethostname(),
        "namespace": "exec",
        "capacity": {"shared_clean": 1, "exclusive": 1},
        "poll_timeout": 25,
        "heartbeat_interval": 15,
    }
    try:
        with open(EXECUTOR_CONFIG_PATH) as f:
            cfg = json.load(f)
    except FileNotFoundError:
        return defaults
    except json.JSONDecodeError as e:
        die(f"{EXECUTOR_CONFIG_PATH} is not valid JSON: {e}")
    merged = {**defaults, **cfg}
    merged["capacity"] = {**defaults["capacity"], **(cfg.get("capacity") or {})}
    return merged


WORKTREES_DIR = os.path.join(ROOT, ".claude", "worktrees")


def worktree_path(name):
    return os.path.join(WORKTREES_DIR, name)


def ensure_worktree(name, base):
    """Create <WORKTREES_DIR>/<name> as a DETACHED checkout at `base` if missing,
    so it never holds a branch and cannot collide with ROOT's checked-out branch."""
    path = worktree_path(name)
    if os.path.isdir(path):
        return path
    subprocess.run(["git", "fetch", "origin", "--prune"], cwd=ROOT, check=True)
    subprocess.run(["git", "worktree", "add", "--detach", path, base],
                   cwd=ROOT, check=True)
    return path


def reset_worktree(path, base):
    """Force `path` to a clean detached checkout of `base`, whatever state it is in.

    A pool worktree is scratch space, but a job that dies mid-run can leave edits
    behind — and `git checkout` REFUSES to clobber them. That is not a small thing:
    an uncommitted edit once sat in work-1 and silently failed every Code stage two
    seconds in, for hours, reported only as "Code stage did not complete". So
    preparing a worktree must never be blockable by leftovers.

    Leftovers are stashed rather than dropped: that stranded edit turned out to
    contain a real fix, so silent destruction is the wrong default. Recover with
    `git stash list` in the worktree. The salvage is best-effort — the hard reset
    runs regardless, so a dirty worktree can never block a job again.
    """
    dirty = subprocess.run(["git", "status", "--porcelain"], cwd=path,
                           capture_output=True, text=True).stdout.strip()
    if dirty:
        log(f"  salvaging leftovers in {path} → git stash (recover with `git stash list`)")
        subprocess.run(["git", "stash", "push", "-u", "-m",
                        f"auto-salvage before {base}"], cwd=path, check=False)
    subprocess.run(["git", "reset", "--hard", "-q"], cwd=path, check=False)
    # -fd, NOT -fdx: gitignored build caches (deps/, _build/, node_modules/) must
    # survive or every job pays a full rebuild.
    subprocess.run(["git", "clean", "-fdq"], cwd=path, check=False)
    subprocess.run(["git", "checkout", "--detach", base], cwd=path, check=False)


def refresh_worktree(name, base):
    """Fast-forward an existing detached worktree to `base`. Caller guarantees the
    worktree is idle (no in-flight job using it)."""
    path = worktree_path(name)
    if not os.path.isdir(path):
        return
    subprocess.run(["git", "fetch", "origin", "--prune"], cwd=ROOT, check=False)
    reset_worktree(path, base)


class ExecutorPool:
    """Executor-local worktree mapping (never sent to the server). Namespace-disjoint from the
    watcher's work pool so both runners run at once.

      shared_clean -> one shared worktree `<ns>-clean`, up to `capacity.shared_clean` concurrent
                      jobs, REUSED (never reset per-job); fast-forwarded to base only when every
                      shared slot is idle (the watcher's scan() discipline).
      exclusive    -> a fixed pool `<ns>-work-1..N`; a slot is BOUND to a run from its first job
                      until the run reaches a terminal run_state, and reset only on that first job
                      (a run's nodes share one worktree — the branch diff is the reviewers' bus).
    """

    def __init__(self, cfg, base="origin/main"):
        self.ns = cfg.get("namespace", "exec")
        self.base = base
        self.cap_shared = cfg["capacity"]["shared_clean"]
        self.cap_excl = cfg["capacity"]["exclusive"]
        self.shared_name = f"{self.ns}-clean"
        self.shared_used = 0
        # exclusive slot name -> run_id it is bound to (None = free)
        self.excl = {f"{self.ns}-work-{i}": None for i in range(1, self.cap_excl + 1)}
        self.lock = threading.Lock()

    def capacity(self):
        """Currently-free capacity per class, for advertising on a claim. A slot bound to a
        parked run counts as NOT free (exclusive affinity is absolute — ADR 0006 §5)."""
        with self.lock:
            return {
                "shared_clean": max(0, self.cap_shared - self.shared_used),
                "exclusive": sum(1 for bound in self.excl.values() if bound is None),
            }

    def has_bound_slots(self):
        """True while any exclusive slot is bound to a run (running or parked). The
        execute loop keeps polling in that case even at 0 free capacity: the bound
        run may have a pinned resume/next job the server hands over regardless of
        advertised capacity (exclusive affinity — ADR 0006 §5)."""
        with self.lock:
            return any(bound is not None for bound in self.excl.values())

    def ensure(self):
        ensure_worktree(self.shared_name, self.base)
        for name in self.excl:
            ensure_worktree(name, self.base)

    def refresh_idle_shared(self):
        """The idle-check and the reset must be one atomic step under the pool lock:
        refresh_worktree()'s hard reset + git clean assumes the worktree is idle for its
        whole duration (see reset_worktree's docstring), so dropping the lock in between
        would let assign() hand the worktree to a job mid-reset."""
        with self.lock:
            if self.shared_used == 0:
                refresh_worktree(self.shared_name, self.base)

    def assign(self, job):
        """Reserve a slot for `job`; return (slot_name, reset?) or None when no slot is free.
        reset? is True only for the first job of an exclusive run."""
        iso = job["isolation"]
        run_id = job["run_id"]
        with self.lock:
            if iso == "shared_clean":
                if self.shared_used >= self.cap_shared:
                    return None
                self.shared_used += 1
                return self.shared_name, False
            for name, bound in self.excl.items():          # reuse the run's own slot
                if bound == run_id:
                    return name, False
            for name, bound in self.excl.items():          # else take a free slot
                if bound is None:
                    self.excl[name] = run_id
                    return name, True
            return None

    def release(self, job, slot, run_state):
        """Free/keep the slot per the outcome's run_state. shared_clean always frees; an
        exclusive slot stays bound while running/parked and unbinds on a terminal state
        (done/failed/cancelled) or a revoke (run_state=None)."""
        with self.lock:
            if job["isolation"] == "shared_clean":
                self.shared_used = max(0, self.shared_used - 1)
                return
            if run_state in ("running", "parked"):
                return
            if slot in self.excl:
                self.excl[slot] = None


def render(template, vars):
    for k, v in vars.items():
        template = template.replace("{" + k + "}", str(v))
    return template


def _print_claude_event(ev, tag=""):
    """Render one stream-json event from a headless claude as a readable feed line."""
    ref = _ref_from_tag(tag)
    t = ev.get("type")
    if t == "assistant":
        for b in ev.get("message", {}).get("content", []):
            if b.get("type") == "text" and b.get("text", "").strip():
                text = b["text"].strip()[:600]
                print(f"    {tag}🤖 " + text, flush=True)
                forward("claude", f"🤖 {text}", ref)
            elif b.get("type") == "tool_use":
                inp = b.get("input", {}) or {}
                brief = (inp.get("command") or inp.get("file_path") or inp.get("path")
                         or inp.get("pattern") or inp.get("description") or "")
                line = f"🔧 {b.get('name')}  {str(brief)[:140]}"
                print(f"    {tag}{line}", flush=True)
                forward("claude", line, ref)
    elif t == "result":
        turns = ev.get("num_turns")
        line = (f"{'✗' if ev.get('is_error') else '✓'} claude finished"
                + (f" ({turns} turns)" if turns else ""))
        print(f"    {tag}{line}", flush=True)
        forward("claude", line, ref)


def _stream_shell(cmd, cwd, tag="", sink=None, on_proc=None):
    """Run a shell step with a live, tag-prefixed feed. Returns True on success.

    On failure the tail of the output is appended to `sink` so the card can carry the
    actual reason. Streaming it to the console alone was not enough: the console is
    not what a human reads later, so a stage that died on one line of git output
    surfaced as a bare "stage did not complete".

    `on_proc`, if given, receives the live Popen so a caller can terminate it (executor
    revoke). Every caller is an executor node-job, which passes `on_proc` (a
    JobControl.register) and so gets its own process group (start_new_session), since only
    a JobControl can kill that group."""
    proc = subprocess.Popen(cmd, shell=True, cwd=cwd, text=True, bufsize=1,
                            stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                            start_new_session=on_proc is not None)
    if on_proc:
        on_proc(proc)
    tail = collections.deque(maxlen=12)
    for line in proc.stdout:
        print(f"    {tag}{line.rstrip()}", flush=True)
        tail.append(line.rstrip())
    ok = proc.wait() == 0
    if not ok and sink is not None:
        sink.extend(tail)
    return ok


class JobControl:
    """Per-job cancel handle: a threading.Event plus the live subprocess, so a heartbeat-borne
    revoke (§5) can terminate the running `claude -p`/shell step even if it registers after the
    revoke arrives."""

    def __init__(self):
        self._cancelled = threading.Event()
        self._proc = None

    def register(self, proc):
        self._proc = proc
        if self._cancelled.is_set():
            self._terminate()

    def cancel(self):
        self._cancelled.set()
        self._terminate()

    def cancelled(self):
        return self._cancelled.is_set()

    def _terminate(self):
        proc = self._proc
        if proc is None or proc.poll() is not None:
            return
        try:
            # _stream_shell runs its command with shell=True, so the registered proc is
            # /bin/sh — a plain terminate() only kills the shell wrapper and leaves the
            # real command running as an orphan that keeps writing into the worktree
            # (including while the next job's reset_worktree() git-reset/cleans it).
            # Anything registered here came through on_proc, so both Popen call sites put
            # it in its own process group (start_new_session=on_proc is not None); killing
            # that group takes the whole command tree with it.
            os.killpg(os.getpgid(proc.pid), signal.SIGTERM)
        except Exception:
            proc.terminate()   # best-effort fallback (e.g. no real pid/process group)


ZERO_CAPACITY = {"shared_clean": 0, "exclusive": 0}


def outdated_refusal(required):
    """What claim_node_job returns on a 409 `executor_outdated` (RLY-184).

    A dict with a key no claim payload has, so the loop tells it apart from a real job by key
    alone — and it carries `required` so the log can name both numbers."""
    return {"executor_outdated": True, "required": required}


def claim_node_job(executor, capacity, timeout):
    """Long-poll claim: hold one request open (advertising free `capacity` per isolation class)
    up to `timeout`s. Returns a job dict, or None on a 204/empty body or a read timeout — both
    mean 'no work', not an error (§7). Returns outdated_refusal(required) when the server
    refuses this executor's version (409 executor_outdated, RLY-184)."""
    try:
        resp = api("POST", "/api/node-jobs/claim",
                   {"executor": executor, "capacity": capacity},
                   soft_conflict=True, timeout=timeout)
    except socket.timeout:
        return None
    error = resp.get("error") if isinstance(resp, dict) else None
    if isinstance(error, dict) and error.get("code") == "executor_outdated":
        return outdated_refusal(error.get("required"))
    return resp or None


def outcome_body(outcome, detail, git_sha, session_id=None):
    """The exact body POSTed to /api/node-jobs/:id/outcome.

    Pure and separate from the POST so bin/test_relay.py can pin its key set against
    test/fixtures/executor_contract.json's `outcome.request` — the same body the ExUnit
    generator posts at the real controller (RLY-176)."""
    return {"outcome": outcome, "detail": detail,
            "git_sha": git_sha, "session_id": session_id}


def heartbeat_body(executor, capacity, running, capabilities=None):
    """The exact body POSTed to /api/node-jobs/heartbeat (RLY-164).

    Pure for the same reason as outcome_body: it is pinned against the fixture's
    `heartbeat.request` (RLY-176). `capabilities` is OPTIONAL and rides send-on-change
    (RLY-182): the key is omitted entirely on a beat where nothing changed, and
    Runs.upsert_executor/2 leaves the stored value alone when the key is absent."""
    body = {"executor": executor, "capacity": capacity, "running": running}
    if capabilities is not None:
        body["capabilities"] = capabilities
    return body


def report_outcome(job_id, outcome, detail, git_sha, session_id=None):
    """POST the typed outcome; return the server-assigned run_state
    (running|parked|done|failed|cancelled) that tells the executor whether to keep or free an
    exclusive slot (§3)."""
    resp = api("POST", f"/api/node-jobs/{job_id}/outcome",
               outcome_body(outcome, detail, git_sha, session_id))
    return (resp or {}).get("run_state")


def _stream_claude_job(prompt, cwd, tag="", session_id=None, outcome_path=None, on_proc=None,
                      agent=None):
    """Executor variant of _stream_claude. Runs `claude -p` (or `--resume <session_id>` on a
    needs-input re-entry), streams events, captures the claude session id from the stream-json
    events (init/result carry `session_id`), and sets $RELAY_NODE_OUTCOME so an agent node can
    signal `partial`. `agent` selects a `.claude/agents/<name>.md` definition via --agent; an
    unknown name makes the CLI fail loudly (verified against 2.1.214) rather than silently
    degrade to the default agent, which is what makes this safe to depend on. Returns
    (ok, captured_session_id). `on_proc` receives the live Popen."""
    cmd = ["claude", "-p", prompt, "--dangerously-skip-permissions",
           "--verbose", "--output-format", "stream-json"]
    if session_id:
        cmd[2:2] = ["--resume", session_id]     # claude -p --resume <session> <prompt>
    if agent:
        cmd += ["--agent", agent]
    child_env = dict(os.environ)
    # `claude -p` caps how long it waits for a background workflow at 10 minutes
    # by default (CLAUDE_CODE_PRINT_BG_WAIT_CEILING_MS, v2.1.182+). A long agent
    # node (implement, final_review) can run past that, and without lifting the cap
    # -p exits mid-run and the node reports a partial result as if it were done.
    # "0" = wait until the work finishes on its own. An explicit env override wins,
    # hence setdefault rather than an unconditional assignment.
    child_env.setdefault("CLAUDE_CODE_PRINT_BG_WAIT_CEILING_MS", "0")
    if outcome_path:
        child_env["RELAY_NODE_OUTCOME"] = outcome_path
    # Every caller is an executor node-job, which passes on_proc (a JobControl.register)
    # and so gets its own process group (start_new_session), since only a JobControl can
    # kill that group.
    proc = subprocess.Popen(cmd, cwd=cwd, text=True, bufsize=1, env=child_env,
                            stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                            start_new_session=on_proc is not None)
    if on_proc:
        on_proc(proc)
    captured = None
    for line in proc.stdout:
        line = line.strip()
        if not line:
            continue
        try:
            ev = json.loads(line)
            captured = ev.get("session_id") or captured
            _print_claude_event(ev, tag)
        except Exception:
            print(f"    {tag}" + line[:200], flush=True)
    return proc.wait() == 0, captured


def determine_agent_outcome(job, ok, outcome_path):
    """Agent-node outcome contract, evaluated in order (agent-integration.md is the write-up):
      1. re-fetch the card — status needs_input ⇒ needs_input (exactly as work() detects today);
      2. else an outcome file at $RELAY_NODE_OUTCOME supplies {outcome, detail} — the only
         way a node signals `partial`;
      3. else NO outcome file ⇒ failed. An agent node must DECLARE its verdict: a `claude -p`
         that exits 0 having written nothing is indistinguishable from one that did the work,
         so treating it as `succeeded` lets a node route past its own gate having produced
         nothing (RLY-163 — the RLY-159 dogfood landed a card in Spec:Review with an empty
         spec exactly this way, and the same hole would let a silent review reach `merge`).
         Rule 1 still covers the legitimate "I stopped to ask a human" case."""
    ref = (job.get("vars") or {}).get("ref")
    if ref:
        card = get_card(ref)
        if card.get("status") == "needs_input":
            return "needs_input", "agent asked the human"
    if outcome_path and os.path.exists(outcome_path):
        try:
            with open(outcome_path) as f:
                data = json.load(f)
            return data.get("outcome", "succeeded"), data.get("detail", "")
        except Exception as e:
            # The outcome file is the ONLY channel a node has to signal `partial`; if it's
            # unreadable/malformed (e.g. an LLM-driven step wrote truncated JSON), falling
            # through to the exit-code check would silently report `succeeded` for a claude
            # -p process that exited 0 but never actually handed back its real outcome. Treat
            # it as `failed` instead, and log so a human can see the node tried to report.
            log(f"  ⚠ {ref}: outcome file at {outcome_path} is unreadable/malformed: {e}",
                ref=ref, kind="error")
            return "failed", f"outcome file at {outcome_path} is unreadable/malformed: {e}"
    if ok:
        return ("failed",
                f"agent exited 0 but did not write an outcome to $RELAY_NODE_OUTCOME "
                f"({outcome_path}) and did not raise needs-input — a node must declare its "
                f"verdict, so this is not treated as success")
    return ("failed", "agent exited non-zero")


def git_head_sha(path):
    """The worktree's HEAD sha, or None when rev-parse fails."""
    proc = subprocess.run(["git", "rev-parse", "HEAD"], cwd=path, capture_output=True, text=True)
    return proc.stdout.strip() if proc.returncode == 0 else None


def reattach_branch(slot_path, isolation, branch, cmd):
    """Point a detached exclusive worktree back at its run's branch (RLY-173).

    `reset_worktree()` ends in `git checkout --detach`, so an interruption leaves an exclusive
    run's worktree detached while the branch ref still holds every commit the run made. RLY-170
    then requeues the orphaned job and it is re-claimed — but it arrives at a detached worktree
    and RLY-166's guard refuses it, forever. Recovery restored the job without restoring the
    place it works.

    Re-attaching is safe precisely because it is not a reset: the branch already points at the
    run's own commits, so `git checkout <branch>` restores exactly the state the run had. If the
    branch does NOT exist locally the guard's refusal is still correct (commits here would reach
    nothing), so this quietly does nothing and lets the guard speak.
    """
    if isolation != "exclusive" or not branch or "checkout -B" in cmd:
        return
    head = subprocess.run(["git", "symbolic-ref", "-q", "HEAD"], cwd=slot_path,
                          capture_output=True, text=True)
    if head.returncode == 0 and head.stdout.strip() == f"refs/heads/{branch}":
        return
    exists = subprocess.run(["git", "rev-parse", "--verify", "-q", f"refs/heads/{branch}"],
                            cwd=slot_path, capture_output=True, text=True)
    if exists.returncode != 0:
        return
    subprocess.run(["git", "checkout", "-q", branch], cwd=slot_path,
                   capture_output=True, text=True)


def check_branch_attached(slot_path, isolation, branch, cmd):
    """Returns a failure detail when this node must NOT run, else None (RLY-166).

    `reset_worktree()` ends in `git checkout --detach` by design, and it runs mid-run on the
    revoke/re-assign path. The `branch` node that ATTACHES HEAD only runs once, at the start of
    a run — so after a mid-run reset every later commit lands on a detached HEAD while the
    named branch ref stays behind. `merge` then pushes the branch ref, shipping a subset of the
    run's work while every gate passes (the gates read the worktree, which is complete; only
    the push reads the ref). The first live Code run merged half its reviewed work that way.

    So: a job that carries a `branch` must run with HEAD actually on that branch. The one
    exception is the node whose whole job is to create it — it legitimately starts detached.
    """
    # Keyed on ISOLATION, not on the branch var: build_payload puts `branch` in vars for every
    # job whether the flow uses it or not, and the shared_clean worktree (exec-clean) is created
    # `--detach` ON PURPOSE so it never holds a branch. Guarding on the var refused every
    # Spec/Plan node the moment this shipped. Only `exclusive` runs commit to a branch and can
    # therefore strand work.
    if isolation != "exclusive" or not branch or "checkout -B" in cmd:
        return None
    proc = subprocess.run(["git", "symbolic-ref", "-q", "HEAD"], cwd=slot_path,
                          capture_output=True, text=True)
    head = proc.stdout.strip() if proc.returncode == 0 else ""
    if head == f"refs/heads/{branch}":
        return None
    where = head or "a detached HEAD"
    return (f"refusing to run: worktree {slot_path} is on {where}, expected refs/heads/{branch}. "
            f"Commits made here would not reach the branch and `merge` would ship a subset of "
            f"this run's work (RLY-166). The run's commits are still in the worktree.")


# Appended to EVERY agent node's prompt. The requirement to declare an outcome must not
# depend on each flow's node prompt or each skill author remembering it — determine_agent_outcome
# now fails a node that writes nothing, so a node never told about the file would always fail.
# Shell/gate nodes are exempt: their exit code is already an unambiguous verdict.
OUTCOME_CONTRACT = """

---
BEFORE YOU FINISH — declare your outcome (required). Run:

    {relay} outcome succeeded --detail "one line on what you did"
    {relay} outcome failed    --detail @/tmp/findings.md

Valid outcomes: succeeded | failed. Use `--detail @file` for anything long or
containing quotes or newlines — do NOT hand-write the JSON yourself; this command writes it.

`detail` is handed to the next node as {prior.detail}, so make it useful: for a review, the
actual findings; for a failure, why. If you need a human instead, run
`{relay} needs-input {ref} --questions @<file>` and stop — that parks the run and you need not
declare an outcome. Exiting without either is reported as `failed`, because a node that
declares nothing cannot be distinguished from one that did nothing."""


def run_node_job(job, slot_path, control):
    """Run one claimed node-job in `slot_path`; return (outcome, detail, git_sha, session_id).
    Reuses the streaming primitives, tagged per job. Does NOT report — the caller POSTs the
    outcome (§6) and acts on the run_state (§3).

    Placeholder expansion ({ref}/{branch}/{relay}/... ) stays executor-side per
    Schemas.Flow.Node/build_payload's contract: the server stores `run` raw and only
    resolves `vars`. `relay`/`url` are not server-sent vars at all — supply them here.
    `is not None` matters: build_payload puts prior_detail/findings in vars as `nil`
    (-> None) when absent, and a naive str(v) would splice the literal string "None"
    into the command."""
    ref = (job.get("vars") or {}).get("ref") or job["id"]
    tag = f"[{ref}] "
    raw_vars = dict(job.get("vars") or {})
    raw_vars.setdefault("ref", ref)
    raw_vars.setdefault("relay", HERE)
    raw_vars.setdefault("url", os.environ.get("RELAY_URL", ""))
    vars = {k: v for k, v in raw_vars.items() if v is not None}
    cmd = render(job["run"], vars)

    # Restore the worktree before judging it: an interrupted run's branch still holds its
    # commits, so re-attach first and let the guard refuse only what is genuinely unrecoverable.
    reattach_branch(slot_path, job.get("isolation"), vars.get("branch"), cmd)
    detached = check_branch_attached(slot_path, job.get("isolation"), vars.get("branch"), cmd)
    if detached:
        log(f"  ⚠ {ref}: {detached}", ref=ref, kind="error")
        return "failed", detached, git_head_sha(slot_path), None

    session_id = None
    if job.get("node_type") == "agent":
        # The outcome file must live OUTSIDE the checkout: reset_worktree() salvages any
        # non-empty `git status --porcelain`, so a file inside slot_path would make every
        # agent job leave a spurious "salvaging leftovers" stash for the next job on this
        # slot. A fresh tempdir per job also means there is never a stale file to read.
        outcome_dir = tempfile.mkdtemp(prefix="relay-node-outcome-")
        outcome_path = os.path.join(outcome_dir, "outcome.json")
        try:
            ok, session_id = _stream_claude_job(
                cmd + render(OUTCOME_CONTRACT, vars), cwd=slot_path, tag=tag,
                session_id=job.get("resume_session"),
                outcome_path=outcome_path, on_proc=control.register, agent=job.get("agent"))
            outcome, detail = determine_agent_outcome(job, ok, outcome_path)
        finally:
            shutil.rmtree(outcome_dir, ignore_errors=True)
    else:  # shell | gate
        tail = []
        ok = _stream_shell(cmd, slot_path, tag, sink=tail, on_proc=control.register)
        outcome = "succeeded" if ok else "failed"
        detail = "" if ok else "\n".join(tail).strip()
    sha_proc = subprocess.run(["git", "rev-parse", "HEAD"], cwd=slot_path,
                              capture_output=True, text=True)
    git_sha = sha_proc.stdout.strip() if sha_proc.returncode == 0 else None
    return outcome, detail, git_sha, session_id


def execute_one(job, slot, reset, control, pool):
    """Worker body for one node-job: reset the slot if it is the run's first exclusive job,
    run the step, and — unless a revoke landed mid-run — report the outcome and return the
    server's run_state. On revoke of an EXCLUSIVE job, reset the worktree (salvaging via
    stash) since it is bound to this job/run alone; a revoked shared_clean job must NOT reset
    exec-clean — capacity.shared_clean lets several jobs run there concurrently, and
    resetting would blow away the others still in flight (the shared worktree is only ever
    fast-forwarded when fully idle, by refresh_idle_shared()). Either way, no outcome is
    reported for a revoke (§5). Always frees/keeps the slot per run_state in a finally (never
    leak a slot)."""
    slot_path = worktree_path(slot)
    run_state = None
    revoked = False
    try:
        if reset and not DRY:
            reset_worktree(slot_path, pool.base)
        outcome, detail, git_sha, session_id = run_node_job(job, slot_path, control)
        if control.cancelled():
            revoked = True
            if not DRY and job.get("isolation") != "shared_clean":
                reset_worktree(slot_path, pool.base)
            return None
        run_state = report_outcome(job["id"], outcome, detail, git_sha, session_id)
        return run_state
    except (Exception, SystemExit) as e:
        # run_node_job (or the report_outcome call above) can raise SystemExit via api()'s
        # die() — e.g. an agent node's determine_agent_outcome calling get_card() when the
        # server is unreachable. SystemExit is a BaseException, not an Exception, so plain
        # `except Exception` would miss it: it would escape this worker thread, and Python's
        # threading module discards uncaught exceptions on non-main threads silently — the
        # job would be lost with no outcome and nothing printed. Catch it here explicitly so
        # this remains the one place that always reports (never leak a slot on crash).
        try:
            run_state = report_outcome(job["id"], "failed", f"worker crashed: {e}", "", None)
        except (Exception, SystemExit) as report_err:
            # a second die() while reporting the crash (server still down) — log rather than
            # let this vanish too.
            log(f"failed to report crash outcome for {job['id']}: {report_err}", kind="error")
            run_state = None
        return run_state
    finally:
        pool.release(job, slot, None if (revoked or control.cancelled()) else run_state)


def cmd_execute(args):
    """The runner mode (ADR 0006): claim node-jobs from the server, run each in an executor
    worktree, and report a typed outcome."""
    global DRY, FORWARDER
    DRY = args.dry_run
    cfg = load_executor_config()
    poll_timeout = args.interval or cfg["poll_timeout"]
    env("RELAY_URL"), env("RELAY_API_KEY")
    executor = executor_ident(cfg)
    pool = ExecutorPool(cfg)
    if not DRY:
        FORWARDER = LogForwarder()
        FORWARDER.start()
        pool.ensure()

    lock = threading.Lock()
    wake = threading.Event()
    stop = threading.Event()
    in_flight = {}   # job-id -> {"thread", "control"}

    def running_ids():
        with lock:
            return list(in_flight)

    def revoke(job_id):
        with lock:
            entry = in_flight.get(job_id)
        if entry:
            entry["control"].cancel()

    def reject(job, detail):
        """A claimed job this executor cannot run — malformed (missing `isolation` or
        `run_id` key, so ExecutorPool.assign raises KeyError before it can even place it;
        an unrecognized-but-present `isolation` value is NOT caught here — assign() treats
        anything other than the literal "shared_clean" as exclusive) or unplaceable (the
        server handed back a job whose isolation class has no free slot here). Untrusted
        server input must not crash the daemon or be dropped silently: report it failed so
        the server's claim lease doesn't sit held-and-running forever, and log it either
        way."""
        job_id = job.get("id") if isinstance(job, dict) else None
        log(f"rejecting claimed job {job_id or job!r}: {detail}", kind="error")
        if job_id is None:
            return
        try:
            report_outcome(job_id, "failed", detail, "", None)
        except (Exception, SystemExit) as e:
            log(f"failed to report rejection for {job_id}: {e}", kind="error")

    outdated = False        # RLY-184: one-way — nothing in-process can pick up new code
    required_version = None

    hb = None
    if not DRY:
        hb = ExecutorHeartbeat(executor, running_ids, revoke,
                               interval=cfg["heartbeat_interval"],
                               capacity=cfg["capacity"])
        # Beat once up front: Relay.Runs.Capacity is empty on a fresh server (it is lost on
        # every restart by design), and until it is fed the scheduler plans zero dispatches.
        # Waiting a full interval here would make "start the executor" look broken.
        hb._beat()
        hb.start()

    def worker(job, slot, reset, control):
        ref = (job.get("vars") or {}).get("ref") or job["id"]
        NODE_JOB_IDS[ref] = job["id"]
        RUN_IDS[ref] = job.get("run_id")
        try:
            execute_one(job, slot, reset, control, pool)
        finally:
            with lock:
                in_flight.pop(job["id"], None)
            NODE_JOB_IDS.pop(ref, None)
            RUN_IDS.pop(ref, None)
            wake.set()

    def _shutdown(*_):
        log("shutting down — no new claims; waiting for in-flight jobs")
        stop.set()
        wake.set()
    signal.signal(signal.SIGINT, _shutdown)

    log(f"executing on {os.environ['RELAY_URL']} as {cfg['name']}"
        + (" (dry-run)" if DRY else "") + (" — one job" if args.once else ""))

    while not stop.is_set():
        if outdated:
            # Refused by the server: stop claiming, but keep beating (zero capacity) so the
            # process stays on the roster wearing its OUTDATED badge instead of vanishing.
            wake.wait(poll_timeout)
            wake.clear()
            continue
        cap = pool.capacity()
        # No free slots → idle, UNLESS an exclusive slot is bound to a run: that
        # run's pinned resume/next job is claimable regardless of advertised
        # capacity (affinity), so we must keep polling or the run never resumes.
        if not DRY and sum(cap.values()) <= 0 and not pool.has_bound_slots():
            wake.wait(poll_timeout)
            wake.clear()
            continue
        if DRY:
            log(f"  (dry) would claim advertising {cap}")
            break
        pool.refresh_idle_shared()
        try:
            job = claim_node_job(executor, cap, poll_timeout)
        except SystemExit as e:                     # exhausted api() retries → die()
            log(f"claim failed, will retry: {e}", kind="error")
            if args.once:
                break
            wake.wait(1)
            wake.clear()
            continue
        if isinstance(job, dict) and job.get("executor_outdated"):
            outdated = True
            required_version = job.get("required")
            if hb:
                hb.capacity = dict(ZERO_CAPACITY)
                hb._beat()          # stop advertising room now, not one interval from now
            log(f"OUTDATED: this executor is running version {EXECUTOR_VERSION} but the "
                f"server requires {required_version} — restart `relay execute` to pick up "
                "current code. No further jobs will be claimed; in-flight work will finish.",
                kind="error")
            if args.once:
                break
            continue
        if job is None:                             # long-poll timeout / 204 → re-poll
            if args.once:
                break
            continue
        try:
            assigned = pool.assign(job)
        except (KeyError, TypeError) as e:          # malformed job: assign can't even read it
            reject(job, f"malformed job: {e}")
            if args.once:
                break
            wake.wait(1)                            # back off — don't hot-loop re-polling
            wake.clear()
            continue
        if assigned is None:                        # no free slot for this job's isolation
            reject(job, f"no free {job.get('isolation')!r} slot advertised {cap}")
            if args.once:
                break
            wake.wait(1)                            # back off — don't hot-loop re-polling
            wake.clear()
            continue
        slot, reset = assigned
        control = JobControl()
        t = threading.Thread(target=worker, args=(job, slot, reset, control), daemon=True)
        with lock:
            in_flight[job["id"]] = {"thread": t, "control": control}
        t.start()
        if args.once:
            t.join()
            break

    for e in list(in_flight.values()):              # join outstanding workers
        e["thread"].join()
    if hb:
        hb.stop()
    if FORWARDER and not DRY:
        FORWARDER.stop()

    if outdated and args.once:
        # No state to sit in for a single-job invocation — a non-zero exit is the right
        # signal to whatever called it.
        die(f"executor version {EXECUTOR_VERSION} is below the server's required "
            f"{required_version} — restart to pick up current code")


NODE_OUTCOMES = ("succeeded", "failed", "partial", "needs_input")


def cmd_outcome(args):
    """Declare this node's outcome by writing $RELAY_NODE_OUTCOME (RLY-175).

    RLY-163 requires every agent node to declare an outcome — a node that writes nothing is
    reported `failed`, because a `claude -p` that exits 0 having done nothing is
    indistinguishable from one that did the work. But that made every agent hand-write JSON
    through a shell heredoc, and a long `detail` containing a quote or a newline produces
    invalid JSON. That is precisely how a drill run died: final_review's outcome file failed to
    parse, the executor correctly reported `failed`, and the PARSE ERROR was handed to
    final_fix as its findings list.

    So the JSON is written by json.dump here, and the agent only has to name an outcome and
    hand over text. `detail` accepts TEXT, "-" (stdin) or "@path", like every other text arg.
    """
    if args.outcome not in NODE_OUTCOMES:
        die(f"outcome must be one of {', '.join(NODE_OUTCOMES)} (got {args.outcome!r})")
    path = os.environ.get("RELAY_NODE_OUTCOME")
    if not path:
        die("RELAY_NODE_OUTCOME is not set — `relay outcome` only runs inside an agent node")
    detail = read_arg(args.detail) if args.detail else ""
    with open(path, "w", encoding="utf-8") as f:
        json.dump({"outcome": args.outcome, "detail": detail}, f)
    return {"outcome": args.outcome}


# ============================ relay init ============================

def _fetch(url, timeout=30):
    """GET a URL with NO credentials, returning raw bytes. `init` runs before a board
    key exists, so it deliberately bypasses api()'s bearer token — the scaffold
    endpoints are public by design (RLY-181)."""
    req = urllib.request.Request(url, method="GET")
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        return resp.read()


def _init_url(args):
    url = args.url or os.environ.get("RELAY_URL")
    if not url:
        die("no board URL — pass --url URL or set RELAY_URL")
    return url.rstrip("/")


def _safe_path(rel):
    """Absolute path for a manifest entry, refusing anything that escapes ROOT. The
    payload comes from our own server, but a scaffold that could write outside the
    project is not a thing to leave to trust."""
    path = os.path.normpath(os.path.join(ROOT, rel))
    if path != ROOT and not path.startswith(ROOT + os.sep):
        die(f"scaffold path escapes the project root: {rel!r}")
    return path


def _classify(path, content, force):
    """One file against disk → (bucket, diff to print). No hash manifest: a file that
    differs is shown as a unified diff and left alone unless --force (RLY-181)."""
    if not os.path.exists(path):
        return "created", ""
    try:
        with open(path, encoding="utf-8") as f:
            existing = f.read()
    except UnicodeDecodeError:
        # A binary/latin-1 file where a template goes. It cannot equal the template and
        # cannot be diffed, so treat it like any other differing file: left alone unless
        # --force. Uniform with every other handled failure path in cmd_init.
        if force:
            return "overwritten", ""
        return "skipped", f"  (not valid UTF-8; cannot diff — {path})\n"
    if existing == content:
        return "unchanged", ""
    if force:
        return "overwritten", ""
    diff = "".join(difflib.unified_diff(
        existing.splitlines(keepends=True),
        content.splitlines(keepends=True),
        fromfile=f"{path} (yours)",
        tofile=f"{path} (template)",
    ))
    return "skipped", diff


def _write_file(path, content, mode):
    os.makedirs(os.path.dirname(path) or ".", exist_ok=True)
    with open(path, "w", encoding="utf-8") as f:
        f.write(content)
    os.chmod(path, int(mode, 8))


def _self_update(url, cli_version):
    """Re-download bin/relay in place when the server advertises a NEWER one; returns
    the new version, or None if it did not fire.

    Only ever UPGRADES: pointing a checkout at an older deployment must not clobber
    that checkout's CLI. An unwritable target is reported, never fatal — a read-only
    install is still perfectly able to scaffold."""
    if cli_version <= EXECUTOR_VERSION:
        return None
    try:
        body = _fetch(url + "/install/relay")
        fd, tmp = tempfile.mkstemp(dir=os.path.dirname(HERE))
        with os.fdopen(fd, "wb") as f:
            f.write(body)
        os.chmod(tmp, 0o755)
        os.replace(tmp, HERE)
    except OSError as e:
        print(f"  ! could not update {HERE}: {e}")
        return None
    return cli_version


def _env_report():
    """The things `init` can check but must never install (ADR 0006 / RLY-181 scope)."""
    return [
        ("this is a git repository", os.path.isdir(os.path.join(ROOT, ".git"))),
        ("`claude` is on PATH", shutil.which("claude") is not None),
        ("RELAY_URL is set", bool(os.environ.get("RELAY_URL"))),
        ("RELAY_API_KEY is set", bool(os.environ.get("RELAY_API_KEY"))),
    ]


def cmd_init(args):
    """Scaffold this project from the board server so its flows can actually run.

    Exit code is 0 whenever the scaffold is on disk (all-skipped included); non-zero
    only for a failure that left the project unscaffolded."""
    url = _init_url(args)
    try:
        doc = json.loads(_fetch(url + "/api/scaffold"))
    except urllib.error.HTTPError as e:
        die(f"GET {url}/api/scaffold failed: HTTP {e.code}")
    except urllib.error.URLError as e:
        die(f"GET {url}/api/scaffold failed: {e.reason}")
    except (json.JSONDecodeError, UnicodeDecodeError) as e:
        die(f"GET {url}/api/scaffold returned something that is not JSON: {e}")

    updated = None
    if not args.no_self_update and not args.dry_run:
        updated = _self_update(url, doc.get("cli_version", 0))

    buckets = collections.OrderedDict(
        (b, []) for b in ("created", "unchanged", "overwritten", "skipped"))

    for entry in doc.get("files", []):
        rel = entry["path"]
        path = _safe_path(rel)
        bucket, diff = _classify(path, entry["content"], args.force)
        buckets[bucket].append(rel)
        if diff:
            print(diff, end="")
        if not args.dry_run and bucket in ("created", "overwritten"):
            try:
                _write_file(path, entry["content"], entry.get("mode", "644"))
            except OSError as e:
                die(f"could not write {rel}: {e}")

    suffix = " (dry run — nothing written)" if args.dry_run else ""
    print(f"\nrelay init — scaffold {doc.get('scaffold_version', '?')} "
          f"from {url}{suffix}")
    for bucket, paths in buckets.items():
        if paths:
            label = "skipped (differs)" if bucket == "skipped" else bucket
            print(f"  {len(paths)} {label}: {', '.join(sorted(paths))}")
    if updated:
        print(f"  bin/relay updated: version {EXECUTOR_VERSION} → {updated} "
              f"(re-run to use it)")

    print("\nStill needed (relay init cannot do these for you):")
    for label, ok in _env_report():
        print(f"  [{'x' if ok else ' '}] {label}")
    print(f"  [ ] mint a board API key: {url} → Settings → API keys")
    print(f"  [ ] export RELAY_URL={url} and RELAY_API_KEY=<that key>")
    print(f"  [ ] enable flows: {url} → Settings → Flows")
    print("  then: bin/relay execute")
    return buckets


# ============================ argparse ============================

def build_parser():
    p = argparse.ArgumentParser(prog="relay", description=__doc__.splitlines()[1])
    sub = p.add_subparsers(dest="cmd")

    def add(name, fn, *pos, json_flag=False):
        sp = sub.add_parser(name)
        for a in pos:
            sp.add_argument(a)
        if json_flag:
            sp.add_argument("--json", action="store_true")
        sp.set_defaults(func=fn)
        return sp

    bd = add("board", cmd_board, json_flag=True)
    bd.add_argument("--include-done", action="store_true")
    add("card", cmd_card, "ref", json_flag=True)
    add("why", cmd_why, "ref", json_flag=True)
    rt = add("retry", cmd_retry, "ref", json_flag=True)
    rt.add_argument("--at")
    add("runs", cmd_runs, "ref", json_flag=True)
    add("executors", cmd_executors, json_flag=True)
    oc = add("outcome", cmd_outcome, "outcome")
    oc.add_argument("--detail")
    c = add("create", cmd_create, "title", json_flag=True)
    c.add_argument("--stage")
    c.add_argument("--description")
    c.add_argument("--tag")
    add("move", _simple(lambda a: move(a.ref, a.stage)), "ref", "stage", json_flag=True)
    add("status", _simple(lambda a: set_status(a.ref, a.status)), "ref", "status", json_flag=True)
    add("describe", _simple(lambda a: set_description(a.ref, read_arg(a.text))), "ref", "text", json_flag=True)
    add("criteria", _simple(lambda a: set_acceptance_criteria(a.ref, read_arg(a.text))), "ref", "text", json_flag=True)
    add("spec", _simple(lambda a: set_spec(a.ref, read_arg(a.text))), "ref", "text", json_flag=True)
    add("plan", _simple(lambda a: set_plan(a.ref, read_arg(a.text))), "ref", "text", json_flag=True)
    add("branch", _simple(lambda a: set_branch(a.ref, a.name)), "ref", "name", json_flag=True)
    add("pr", _simple(lambda a: set_pr_url(a.ref, a.url)), "ref", "url", json_flag=True)
    tg = add("tag", _simple(lambda a: set_tag(a.ref, a.value)), "ref", json_flag=True)
    tg.add_argument("value", nargs="?")
    add("sub-tasks", _simple(lambda a: set_sub_tasks(a.ref, read_arg(a.text))), "ref", "text", json_flag=True)
    add("check", _simple(lambda a: set_sub_task_done(a.ref, a.id, True)), "ref", "id", json_flag=True)
    add("uncheck", _simple(lambda a: set_sub_task_done(a.ref, a.id, False)), "ref", "id", json_flag=True)
    add("result", _simple(lambda a: set_result(a.ref, read_arg(a.text))), "ref", "text", json_flag=True)
    ni = add("needs-input", cmd_needs_input, "ref", json_flag=True)
    ni.add_argument("question", nargs="?")
    ni.add_argument("--questions")
    add("own", _simple(lambda a: own(a.ref)), "ref", json_flag=True)
    add("release", _simple(lambda a: release(a.ref)), "ref", json_flag=True)
    add("approve", _simple(lambda a: api("POST", f"/api/cards/{a.ref}/approve", {})["data"]), "ref", json_flag=True)
    add("reject", cmd_reject, "ref", "note", json_flag=True)
    add("comment", cmd_comment, "ref", "text")
    at = add("attach", cmd_attach, "ref", "file", json_flag=True)
    at.add_argument("--caption")
    ex = add("execute", cmd_execute)
    ex.add_argument("--once", action="store_true")
    ex.add_argument("--dry-run", action="store_true")
    ex.add_argument("--interval", type=int)
    ini = add("init", cmd_init)
    ini.add_argument("--url")
    ini.add_argument("--force", action="store_true")
    ini.add_argument("--dry-run", action="store_true")
    ini.add_argument("--no-self-update", action="store_true")
    return p


def main():
    parser = build_parser()
    args = parser.parse_args()
    if not getattr(args, "cmd", None):
        # The board runner is gone (RLY-139): dispatch is server-side now, and this
        # binary's runner mode is `relay execute`.
        parser.print_help()
        return
    args.func(args)


if __name__ == "__main__":
    main()
